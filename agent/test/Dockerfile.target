# 멀티유저 SSH 테스트용 타겟 서버 이미지
# jeussic 계정 — SSH 접속 + app.log / batch.log 1초 주기 에러 로그 자동 생성
# ※ agent 바이너리는 frontend install 흐름(SFTP 업로드)으로 배포하므로 포함하지 않음
# Phase OTel: OpenJDK 8 + SampleApp 포함 (OTel end-to-end 검증용)

# ── Stage 1: SampleApp 컴파일 ────────────────────────────────────────────────
FROM debian:bookworm-slim AS builder

RUN apt-get update && apt-get install -y \
    openjdk-17-jdk-headless \
    && rm -rf /var/lib/apt/lists/*

COPY test/sample-app/SampleApp.java /build/SampleApp.java
RUN javac -encoding UTF-8 -source 8 -target 8 -d /build /build/SampleApp.java && \
    echo "Main-Class: SampleApp" > /build/manifest.txt && \
    # PostgreSQL JDBC 드라이버를 classpath에 등록 (runtime stage와 동일 경로)
    echo "Class-Path: /usr/share/java/postgresql.jar" >> /build/manifest.txt && \
    (cd /build && jar cfm /build/SampleApp.jar manifest.txt SampleApp*.class)

# ── Stage 2: 런타임 이미지 ───────────────────────────────────────────────────
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    openssh-server \
    bash \
    curl \
    openjdk-17-jre-headless \
    libpostgresql-jdbc-java \
    && rm -rf /var/lib/apt/lists/*
# libpostgresql-jdbc-java가 /usr/share/java/postgresql.jar → postgresql-X.Y.Z.jar symlink 자동 생성

# SSH 데몬 설정: 비밀번호 인증 허용 (테스트 전용)
RUN mkdir -p /var/run/sshd && \
    sed -i 's/#PasswordAuthentication yes/PasswordAuthentication yes/' /etc/ssh/sshd_config && \
    sed -i 's/PasswordAuthentication no/PasswordAuthentication yes/' /etc/ssh/sshd_config && \
    echo "PermitRootLogin no" >> /etc/ssh/sshd_config

# 테스트 계정 생성 (비밀번호: test123)
RUN useradd -m -s /bin/bash jeussic && echo "jeussic:test123" | chpasswd

# synapse agent WAL 디렉터리 사전 생성 (OTel은 jeussic이 admin-api install 시 ~/otel에 스스로 mkdir)
RUN mkdir -p /home/jeussic/synapse/wal /home/jeussic/otel && \
    chown -R jeussic:jeussic /home/jeussic/

# SampleApp JAR 배치 — 서비스 계정(jeussic) 홈에 배치 (운영 WAS 기동 계정 패턴과 동일)
RUN mkdir -p /home/jeussic/sample-app
COPY --from=builder /build/SampleApp.jar /home/jeussic/sample-app/SampleApp.jar
RUN chown -R jeussic:jeussic /home/jeussic/sample-app

# 로그 생성 스크립트
COPY test/generate-logs.sh /usr/local/bin/generate-logs.sh
RUN chmod +x /usr/local/bin/generate-logs.sh

# 진입점
COPY test/entrypoint-target.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 22 8081

ENTRYPOINT ["/entrypoint.sh"]
