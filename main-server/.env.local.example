# 로컬 개발 환경변수 — 복사 후 .env.local로 저장
# cp .env.local.example .env.local

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://synapse:synapse@localhost:5432/synapse

# ── Prometheus ───────────────────────────────────────────────────────────────
# admin-api가 Prometheus를 직접 쿼리할 때 사용 (호스트에서 직접 실행 시)
PROMETHEUS_URL=http://localhost:9090
# synapse_agent Docker 컨테이너가 Prometheus에 remote write할 때 사용
# Docker 컨테이너 내부에서 호스트 Prometheus에 접근하는 주소
AGENT_PROMETHEUS_URL=http://host.docker.internal:9090

# ── 서비스 간 통신 (로컬에서 직접 실행 시) ─────────────────────────────────
ADMIN_API_URL=http://localhost:8080
LOG_ANALYZER_URL=http://localhost:8000

# ── 벡터 DB / 임베딩 (로컬 Docker) ───────────────────────────────────────────
QDRANT_URL=http://localhost:6333
OLLAMA_URL=http://localhost:11434   # ollama 컨테이너 활성화 시
EMBED_MODEL=bge-m3

# ── LLM 설정 ─────────────────────────────────────────────────────────────────
# LLM_TYPE: devx(운영 내부) | ollama(로컬) | claude(Anthropic) | openai(OpenAI)
LLM_TYPE=ollama
LLM_API_URL=http://localhost:11434
LLM_API_KEY=
LLM_AGENT_CODE=
LLM_MODEL=llama3

# ── Teams Webhook ─────────────────────────────────────────────────────────────
# 로컬 테스트용: https://webhook.site 에서 임시 URL 발급 후 입력
# 빈 값으로 두면 알림 발송을 건너뜀
TEAMS_WEBHOOK_URL=

# ── log-analyzer 분석 주기 ───────────────────────────────────────────────────
ANALYSIS_INTERVAL_SECONDS=300

# ── Teams 피드백 버튼 URL (브라우저에서 접근 가능한 frontend 주소) ───────────
# Teams 알림 카드의 "해결책 등록" 버튼이 이 주소의 React 페이지(/feedback/submit)로 연결됨
# 로컬: http://localhost:3001  운영: http://{server-a-ip}:3001
FRONTEND_EXTERNAL_URL=http://localhost:3001

# ── synapse_agent 바이너리 경로 (로컬 개발용) ────────────────────────────────
# Docker 이미지 내부: /app/bin/agent-v (기본값)
# 로컬 개발: agent/dist/agent-v 절대경로 지정
AGENT_BINARY_PATH=

# ── 공통 Fernet 키 (DB 수집기 자격증명 · 챗봇 executor 자격증명 공용) ───────────
# Fernet 키 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 로컬 테스트용으로도 설정해야 db AgentInstance install / 챗봇 executor 자격증명이 동작함
ENCRYPTION_KEY=
ORACLE_COLLECT_INTERVAL_SECS=60
