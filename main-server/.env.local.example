# 로컬 개발 환경변수 — 복사 후 .env.local로 저장
# cp .env.local.example .env.local

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://synapse:synapse@localhost:5432/synapse

# ── Prometheus ───────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090

# ── 서비스 간 통신 (로컬에서 직접 실행 시) ─────────────────────────────────
ADMIN_API_URL=http://localhost:8080
LOG_ANALYZER_URL=http://localhost:8000

# ── 벡터 DB / 임베딩 (로컬 Docker) ───────────────────────────────────────────
QDRANT_URL=http://localhost:6333
OLLAMA_URL=http://localhost:11434   # ollama 컨테이너 활성화 시
EMBED_MODEL=bge-m3

# ── 외부 LLM API ──────────────────────────────────────────────────────────────
LLM_API_URL=
LLM_API_KEY=
LLM_AGENT_CODE=

# ── Teams Webhook ─────────────────────────────────────────────────────────────
# 로컬 테스트용: https://webhook.site 에서 임시 URL 발급 후 입력
# 빈 값으로 두면 알림 발송을 건너뜀
TEAMS_WEBHOOK_URL=

# ── log-analyzer 분석 주기 ───────────────────────────────────────────────────
ANALYSIS_INTERVAL_SECONDS=300

# ── n8n (WF3 피드백 폼 action URL) ───────────────────────────────────────────
# admin-api 피드백 폼에서 n8n webhook으로 POST할 때 사용
# 로컬: http://localhost:5678  운영: http://{server-a-ip}:5678
N8N_WEBHOOK_URL=http://localhost:5678

# ── Teams 피드백 버튼 URL (브라우저에서 접근 가능한 admin-api 주소) ──────────
# Teams 알림 카드의 "해결책 등록" 버튼이 이 주소의 피드백 폼으로 연결됨
# 로컬: http://localhost:8080  운영: http://{server-a-ip}:8080
ADMIN_API_EXTERNAL_URL=http://localhost:8080

# ── Oracle DB 수집기 (Phase 9) ────────────────────────────────────────────────
# Fernet 키 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 로컬 테스트용으로도 설정해야 oracle_db AgentInstance install이 동작함
DB_ENCRYPTION_KEY=
ORACLE_COLLECT_INTERVAL_SECS=60
