# ==============================================================================
# .env.local — 로컬 개발 환경변수 (서비스별 구분)
# ==============================================================================
# 주입 경로:  .env.local → docker-compose(.dev).yml → 각 컨테이너
# 수정 후 해당 컨테이너 재시작 필요:
#   docker compose -f docker-compose.dev.yml up -d <service>
# 표기:
#   [필수] = 없으면 서비스 동작 불가 또는 보안상 반드시 설정해야 함
#   [옵션] = 기본값 있음 / 비워도 동작
# ==============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# ---- 공통 인프라 (PostgreSQL / Prometheus) ----
# ─────────────────────────────────────────────────────────────────────────────

# [필수] PostgreSQL — admin-api, log-analyzer, n8n 공통
DATABASE_URL=postgresql+asyncpg://synapse:synapse@localhost:5432/synapse

# [필수] Prometheus — admin-api의 메트릭 교차 분석용 (호스트 실행 시)
PROMETHEUS_URL=http://localhost:9090

# [옵션] synapse_agent(Docker) → 호스트 Prometheus remote-write 주소
#   routes/agents.py 가 agent config.toml 생성 시 참조
AGENT_PROMETHEUS_URL=http://host.docker.internal:9090


# ─────────────────────────────────────────────────────────────────────────────
# ---- admin-api (FastAPI, port 8080) ----
# ─────────────────────────────────────────────────────────────────────────────

# --- 인증 / 보안 ---
# [필수] JWT 서명 키 (운영 배포 시 반드시 교체)
SECRET_KEY=c990dab80fd7966d511c08391c3927f333c196755502ccadf9c1b0a59c5fdf52
# [필수] DB 수집기 크리덴셜 암호화 Fernet 키
#   생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DB_ENCRYPTION_KEY=sB1-o4ic3XebK8WwtBEJEp5KDW1dsGzHOVw3GxNQW9A=

# [옵션] JWT 만료
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# [옵션] HTTPS 환경에서만 true (로컬 dev: false)
COOKIE_SECURE=false
# [옵션] CORS 허용 도메인 (쉼표 구분)
CORS_ORIGINS=http://localhost:3001

# --- 서비스 간 통신 ---
# [필수] log-analyzer 주소 (알림 유사도 분석 / 피드백 전파 호출)
LOG_ANALYZER_URL=http://localhost:8000
# [필수] Teams 카드 "해결책 등록" 버튼이 여는 React 페이지 외부 접근 URL
#   로컬 단독 테스트: http://localhost:3001
#   사내망 공유 테스트: http://{호스트-IP}:3001  (Teams가 사용자 PC 브라우저에서 열리므로 localhost 불가)
#   운영: http://{server-a-ip}:3001
FRONTEND_EXTERNAL_URL=http://10.149.217.227:3001

# --- 에이전트 / DB 수집기 ---
# [옵션] synapse_agent 바이너리 경로
#   비우면 컨테이너 기본값(/app/bin/agent-v) 사용
AGENT_BINARY_PATH=/Users/youwonji/workspace/ai/aoms/agent/dist/agent-v
# [옵션] DB 메트릭 수집 주기(초)
#   신규 키: DB_COLLECT_INTERVAL_SECS — 아래 값은 하위호환 (둘 다 인식)
ORACLE_COLLECT_INTERVAL_SECS=60

# --- Prometheus 교차 분석 임계치 (services/prometheus_analyzer.py) ---
# [옵션] 모두 기본값 있음. 필요 시 주석 해제
# PROM_ALERT_CPU_THRESHOLD=85.0
# PROM_ALERT_MEM_THRESHOLD=85.0
# PROM_ALERT_HTTP_SLOW_MS=3000.0
# PROM_ALERT_LOG_ERROR_RATE=5.0
# PROMETHEUS_ANALYZE_INTERVAL_SECONDS=300


# ─────────────────────────────────────────────────────────────────────────────
# ---- log-analyzer (FastAPI, port 8000) ----
# ─────────────────────────────────────────────────────────────────────────────

# [옵션] 로그 분석 주기 (기본 300초)
ANALYSIS_INTERVAL_SECONDS=300

# --- 벡터 DB / 임베딩 (Server B) ---
# [필수] Ollama 임베딩 서버
OLLAMA_URL=http://10.253.21.105:11434
# [필수] 임베딩 모델 — ADR-003: paraphrase-multilingual (768dim)
EMBED_MODEL=paraphrase-multilingual
# [필수] Qdrant 벡터 DB
QDRANT_URL=http://10.253.21.105:6333

# [필수] log-analyzer → admin-api 호출 주소
#   로컬 직접 실행: http://localhost:8080  /  Docker Compose 내부: http://admin-api:8080
ADMIN_API_URL=http://localhost:8080


# ─────────────────────────────────────────────────────────────────────────────
# ---- 공통 LLM 설정 (admin-api + log-analyzer, ADR-001) ----
# ─────────────────────────────────────────────────────────────────────────────
# llm_client.py Strategy 가 LLM_TYPE 에 따라 라우팅
#   devx(운영 내부) | ollama(로컬) | claude(Anthropic) | openai(OpenAI)

# [필수] 프로바이더
LLM_TYPE=devx
# [옵션] 모델 식별자 (프로바이더별 상이)
LLM_MODEL=
# DevX OAuth (client_credentials) — agent_code는 DB llm_agent_configs에서 영역별 관리
DEVX_CLIENT_ID=s2s-iS7Aqbz7r89DI49Phosq
DEVX_CLIENT_SECRET=vYV7gj7BNAL1OFbWLUNnuCqBXjvQdJ92


# ─────────────────────────────────────────────────────────────────────────────
# ---- Teams (admin-api + n8n 공통, 전역 폴백 Webhook) ----
# ─────────────────────────────────────────────────────────────────────────────
# 시스템별 `systems.teams_webhook_url`이 우선. 비우면 알림 건너뜀
# 로컬 테스트: https://webhook.site 에서 임시 URL 발급 권장

# [옵션]
TEAMS_WEBHOOK_URL=https://shinsegaegroup.webhook.office.com/webhookb2/cf4de980-8cba-4596-a125-a584eebfbc2a@d4ffc887-d88d-41cc-bf6a-6bb47ec0f3ca/IncomingWebhook/0423cd5200e14fda8e1236d679afdaca/ad16669e-72ea-47e2-a53c-49a4772155d3/V2Rj76gvhHXygq0KsM6IeptTnzOCPli56wPXjKm6onPdg1


# ─────────────────────────────────────────────────────────────────────────────
# ---- n8n (Workflow 자동화, port 5678) ----
# ─────────────────────────────────────────────────────────────────────────────

# [필수] Basic Auth 계정
N8N_USER=synapse
N8N_PASSWORD=deptcx_synapse
# [필수] 운영 docker-compose.yml의 WEBHOOK_URL 조합에 사용
#   (외부에서 n8n webhook 접근 시 사용되는 서버 IP)
MONITORING_SERVER_IP=10.253.21.106


# ─────────────────────────────────────────────────────────────────────────────
# ---- frontend (Vite, 빌드타임 변수) ----
# ─────────────────────────────────────────────────────────────────────────────
# 프론트엔드는 빌드 시 번들에 포함되므로 docker-compose 런타임 주입 불가.
# 실제 설정은 services/frontend/.env.local 파일에 별도 작성:
#   VITE_ADMIN_API_URL=http://localhost:8080
#   VITE_LOG_ANALYZER_URL=http://localhost:8000


# ─────────────────────────────────────────────────────────────────────────────
# ---- 운영 docker-compose.yml 전용 (로컬 dev 에선 불필요) ----
# ─────────────────────────────────────────────────────────────────────────────
# 운영 배포 시 별도 .env 또는 배포 환경에 정의
# DB_USER=synapse
# DB_PASSWORD=synapse
# GRAFANA_ADMIN_PASSWORD=admin
# PROM_USER=admin
# PROM_PASS=synapse
