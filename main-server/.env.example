GRAFANA_ADMIN_PASSWORD=aoms
DB_USER=aoms
DB_PASSWORD=aoms

# Prometheus Basic Auth (web.yml의 bcrypt 해시와 동일한 비밀번호)
PROMETHEUS_PASS=''
PROM_USER=admin
PROM_PASS=aoms

# LLM 설정 — LLM_TYPE: devx(운영 내부) | claude(Anthropic) | openai(OpenAI)  ※ ADR-012: ollama 폐지
LLM_TYPE=devx
LLM_API_URL=
LLM_MODEL=
# DevX OAuth (client_credentials)
DEVX_CLIENT_ID=
DEVX_CLIENT_SECRET=

# Microsoft Teams Incoming Webhook URL
TEAMS_WEBHOOK_URL=https://shinsegaegroup.webhook.office.com

# n8n 워크플로우 자동화
N8N_USER=aoms
N8N_PASSWORD=aoms
MONITORING_SERVER_IP=110

# 벡터 DB + 임베딩 설정 (ADR-011: Ollama 제거 → FastEmbed ONNX 인프로세스)
# 모델 ONNX 파일은 log-analyzer Docker 이미지에 번들됨 (Dockerfile에서 빌드 시 1회 다운로드)
# 수기 배포·볼륨 마운트 불필요. DENSE/SPARSE 모델 변경 시에만 값 지정.
QDRANT_URL=http://111:6333                           # sub-server (Server B)
# DENSE_EMBED_MODEL=BAAI/bge-m3                      # 기본값 — FastEmbed 지원 모델, 1024 dim
# SPARSE_EMBED_MODEL=Qdrant/bm25                     # 기본값 — BM25 sparse (IDF 기반)

# ── OTel / Tempo (Phase OTel) ─────────────────────────────────────────────────
TEMPO_URL=http://tempo:3200
OTEL_COLLECTOR_ENDPOINT=http://otel-collector:4317

# ── 공통 Fernet 키 (DB 수집기 자격증명 · 챗봇 executor 자격증명 공용) ───────────
# Fernet 키 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here
ORACLE_COLLECT_INTERVAL_SECS=60
