# ==============================================================================
# .env.example — 운영 환경변수 템플릿
# ==============================================================================
# 이 파일을 복사하여 .env 로 사용하거나, 배포 환경에 직접 값을 설정하세요.
# [필수] = 없으면 서비스 동작 불가 / 보안상 반드시 설정
# [옵션] = 기본값 있음 / 비워도 동작
# ==============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# ---- 공통 인프라 (PostgreSQL / Prometheus / Grafana) ----
# ─────────────────────────────────────────────────────────────────────────────
# docker-compose 가 DATABASE_URL 을 자동 조합: postgresql+asyncpg://synapse:{DB_PASSWORD}@postgres:5432/synapse

# [필수]
GRAFANA_ADMIN_PASSWORD=admin
DB_USER=synapse
DB_PASSWORD=synapse

# Prometheus Basic Auth (web.yml의 bcrypt 해시와 동일한 비밀번호)
#PROMETHEUS_PASS=''
PROM_USER=admin
PROM_PASS=synapse


# ─────────────────────────────────────────────────────────────────────────────
# ---- 인증 / 보안 (admin-api) ----
# ─────────────────────────────────────────────────────────────────────────────

# [필수] JWT 서명 키 — 운영 배포 시 반드시 새로 생성
#   생성: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=c990dab80fd7966d511c08391c3927f333c196755502ccadf9c1b0a59c5fdf52

# [필수] Fernet 대칭키 — DB 수집기 + 챗봇 executor 자격증명 공용
#   생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=sB1-o4ic3XebK8WwtBEJEp5KDW1dsGzHOVw3GxNQW9A=

# [필수] CORS 허용 도메인 — React 프론트엔드 접근 URL (쉼표 구분)
CORS_ORIGINS=http://10.253.21.106:3001


# ─────────────────────────────────────────────────────────────────────────────
# ---- LLM 설정 (admin-api + log-analyzer, ADR-001) ----
# ─────────────────────────────────────────────────────────────────────────────
# llm_client.py Strategy 가 LLM_TYPE 에 따라 라우팅
# devx(운영 내부) | claude(Anthropic) | openai(OpenAI)  ※ ADR-012: ollama 폐지

# [필수]
LLM_TYPE=devx
LLM_API_URL=
LLM_MODEL=

# [필수] DevX OAuth (client_credentials) — agent_code는 DB llm_agent_configs에서 영역별 관리
DEVX_CLIENT_ID=s2s-iS7Aqbz7r89DI49Phosq
DEVX_CLIENT_SECRET=vYV7gj7BNAL1OFbWLUNnuCqBXjvQdJ92


# ─────────────────────────────────────────────────────────────────────────────
# ---- 서비스 연동 (admin-api) ----
# ─────────────────────────────────────────────────────────────────────────────

# [필수] Teams 카드 "해결책 등록" 버튼이 여는 React 페이지 외부 접근 URL
#   Teams가 사용자 PC 브라우저에서 열리므로 서버 IP 필요 (localhost 불가)
FRONTEND_EXTERNAL_URL=http://10.253.21.106:3001

# [옵션] synapse_agent remote-write 대상 Prometheus URL
#   CLI 에이전트 미사용 시 비워도 무방
AGENT_PROMETHEUS_URL=http://10.253.21.106:9090


# ─────────────────────────────────────────────────────────────────────────────
# ---- Microsoft Teams Incoming Webhook ----
# ─────────────────────────────────────────────────────────────────────────────
# 시스템별 systems.teams_webhook_url이 우선. 비우면 알림 건너뜀.

# [옵션] 전역 폴백 Webhook URL
TEAMS_WEBHOOK_URL=https://shinsegaegroup.webhook.office.com/webhookb2/cf4de980-8cba-4596-a125-a584eebfbc2a@d4ffc887-d88d-41cc-bf6a-6bb47ec0f3ca/IncomingWebhook/0423cd5200e14fda8e1236d679afdaca/ad16669e-72ea-47e2-a53c-49a4772155d3/V2Rj76gvhHXygq0KsM6IeptTnzOCPli56wPXjKm6onPdg1


# ─────────────────────────────────────────────────────────────────────────────
# ---- n8n (워크플로우 자동화, port 5678) ----
# ─────────────────────────────────────────────────────────────────────────────

# [필수] Basic Auth 계정
N8N_USER=synapse
N8N_PASSWORD=deptcx_synapse
# [필수] 외부에서 n8n webhook 접근 시 사용되는 서버 A IP (WEBHOOK_URL 조합용)
MONITORING_SERVER_IP=10.253.21.106


# ─────────────────────────────────────────────────────────────────────────────
# ---- 벡터 DB + 임베딩 설정 (ADR-011: FastEmbed ONNX 인프로세스) ----
# ─────────────────────────────────────────────────────────────────────────────
# Dense/Sparse 모델은 Docker 이미지에 번들됨 — 변경 시에만 값 지정
# HF_HUB_OFFLINE=1 은 docker-compose.yml에서 하드코딩 (폐쇄망 안전장치)

# [필수] Qdrant 벡터 DB (Server B)
QDRANT_URL=http://10.253.21.105:6333
# [옵션] Dense 모델 변경 시만 지정 (기본: BAAI/bge-m3, 1024 dim)
# DENSE_EMBED_MODEL=BAAI/bge-m3
# [옵션] Sparse 모델 변경 시만 지정 (기본: Qdrant/bm25)
# SPARSE_EMBED_MODEL=Qdrant/bm25


# ─────────────────────────────────────────────────────────────────────────────
# ---- DB 수집기 ----
# ─────────────────────────────────────────────────────────────────────────────

# [옵션] Oracle/DB 수집 주기 (초, 기본 60)
ORACLE_COLLECT_INTERVAL_SECS=60


# ─────────────────────────────────────────────────────────────────────────────
# ---- V1 knowledge ingestion 파이프라인 (Jira / Confluence) ----
# ─────────────────────────────────────────────────────────────────────────────
# 미사용 시 빈 값 가능. KNOWLEDGE_SYNC_RATE_LIMIT는 초당 API 호출 수 제한.

JIRA_URL=https://jira.example.com
JIRA_TOKEN=your_jira_pat_here
JIRA_PROJECTS=PAYMENT,INFRA,POLICY
CONFLUENCE_URL=https://confluence.example.com
CONFLUENCE_TOKEN=your_confluence_pat_here
CONFLUENCE_SPACES=OPS,POLICY
KNOWLEDGE_SYNC_RATE_LIMIT=5
