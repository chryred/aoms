GRAFANA_ADMIN_PASSWORD=aoms
DB_USER=aoms
DB_PASSWORD=aoms

# Prometheus Basic Auth (web.yml의 bcrypt 해시와 동일한 비밀번호)
PROMETHEUS_PASS=''
PROM_USER=admin
PROM_PASS=aoms

# LLM 설정 — LLM_TYPE: devx(운영 내부) | ollama(로컬) | claude(Anthropic) | openai(OpenAI)
LLM_TYPE=devx
LLM_API_URL=
LLM_API_KEY=
LLM_AGENT_CODE=
LLM_MODEL=

# Microsoft Teams Incoming Webhook URL
TEAMS_WEBHOOK_URL=https://shinsegaegroup.webhook.office.com

# n8n 워크플로우 자동화
N8N_USER=aoms
N8N_PASSWORD=aoms
MONITORING_SERVER_IP=110

# ollama, qdrand  설저  설정
OLLAMA_URL=http://111:11434   # sub-server
EMBED_MODEL=bge-m3
QDRANT_URL=http://111:6333    # sub-server

# ── Oracle DB 수집기 (Phase 9) ────────────────────────────────────────────────
# Fernet 키 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DB_ENCRYPTION_KEY=your_fernet_key_here
ORACLE_COLLECT_INTERVAL_SECS=60
